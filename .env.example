# SerendipityLab — Environment Variables
# Copy this file to .env.local and fill in the values you need.
# All variables are optional. The app works fully without any API keys
# using the built-in rule-based generation engine.

# ──────────────────────────────────────────────────────────────────────────────
# Phase 4: LLM Enhancement (optional)
# When one of these keys is present, concept decomposition and fusion
# descriptions are enriched via LLM calls. Without them the rule-based
# engine is used exclusively.
# ──────────────────────────────────────────────────────────────────────────────

# OpenAI — used if present (takes priority over Gemini)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini   # default: gpt-4o-mini

# Google Gemini — used as fallback when OPENAI_API_KEY is not set
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-1.5-flash   # default: gemini-1.5-flash
